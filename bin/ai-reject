#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import datetime
from pathlib import Path
import sys


REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from core.approval import GATE_CONFIGS, render_approval
from core.safe_write import safe_write_bytes
from core.state import (
    STATE_RELATIVE_PATH,
    update_state_for_final_rejected,
    update_state_for_plan_rejected,
    update_state_for_spec_rejected,
    load_state,
    update_state_for_diff_rejected,
    write_state_payload,
)
from core.state_machine import assert_waiting_gate_for_decision

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Reject a harness gate decision.")
    parser.add_argument("gate", choices=["spec", "plan", "diff", "final"])
    parser.add_argument("--force", action="store_true", help="overwrite existing approval material after backing it up")
    return parser.parse_args()


def require_waiting_gate(target_root: Path, gate: str) -> dict:
    config = GATE_CONFIGS[gate]
    state_path = target_root / STATE_RELATIVE_PATH
    if not state_path.exists():
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")

    state = load_state(target_root)
    if state is None:
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")
    assert_waiting_gate_for_decision(state, gate, action="rejection")
    if not (target_root / config.review_path).exists():
        raise RuntimeError(f"missing required review material: {config.review_path.as_posix()}")
    return state


def main() -> int:
    try:
        args = parse_args()
        target_root = Path.cwd()
        config = GATE_CONFIGS[args.gate]
        state = require_waiting_gate(target_root, args.gate)
        timestamp = datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")

        approval_result = safe_write_bytes(
            target_root=target_root,
            relative_path=config.approval_path,
            content=render_approval(config=config, approved=False).encode("utf-8"),
            force=args.force,
            timestamp=timestamp,
        )

        line = f"{approval_result.action} {approval_result.path.relative_to(target_root).as_posix()}"
        if approval_result.backup_path is not None:
            line += f" (backup: {approval_result.backup_path.relative_to(target_root).as_posix()})"
        print(line)

        if approval_result.action in {"CREATED", "OVERWRITTEN"}:
            updated_state = {
                "spec": update_state_for_spec_rejected,
                "plan": update_state_for_plan_rejected,
                "diff": update_state_for_diff_rejected,
                "final": update_state_for_final_rejected,
            }[args.gate](state)
            state_result = write_state_payload(
                target_root=target_root,
                state=updated_state,
                force=True,
                timestamp=timestamp,
            )
            state_line = f"{state_result.action} {state_result.path.relative_to(target_root).as_posix()}"
            if state_result.backup_path is not None:
                state_line += f" (backup: {state_result.backup_path.relative_to(target_root).as_posix()})"
            print(state_line)
        else:
            print("state unchanged; use --force to regenerate approval")

        return 0
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
