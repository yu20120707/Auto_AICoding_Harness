#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import datetime
import json
from pathlib import Path
import sys


REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from core.approval import GATE_CONFIGS, render_approval
from core.review_gate import render_decision_approval_json, task_approval_relative_path, task_status_for_decision, update_task_payload_status
from core.rca import check_rule_draft_relative_path, render_check_rule_draft, render_check_rules_index, render_rca, rca_relative_path, INDEX_PATH
from core.safe_write import safe_write_bytes
from core.state import (
    STATE_RELATIVE_PATH,
    update_state_for_final_rejected,
    update_state_for_plan_rejected,
    update_state_for_spec_rejected,
    load_state,
    update_state_for_diff_rejected,
    write_state_payload,
)
from core.state_machine import assert_waiting_gate_for_decision
from core.task_state import active_task_supplement_relative_path, load_active_task_supplement

def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Reject a harness gate decision.")
    parser.add_argument("gate", choices=["spec", "plan", "diff", "final"])
    parser.add_argument("--force", action="store_true", help="overwrite existing approval material after backing it up")
    return parser.parse_args()


def require_waiting_gate(target_root: Path, gate: str) -> dict:
    config = GATE_CONFIGS[gate]
    state_path = target_root / STATE_RELATIVE_PATH
    if not state_path.exists():
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")

    state = load_state(target_root)
    if state is None:
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")
    assert_waiting_gate_for_decision(state, gate, action="rejection")
    if not (target_root / config.review_path).exists():
        raise RuntimeError(f"missing required review material: {config.review_path.as_posix()}")
    return state


def main() -> int:
    try:
        args = parse_args()
        target_root = Path.cwd()
        config = GATE_CONFIGS[args.gate]
        state = require_waiting_gate(target_root, args.gate)
        timestamp = datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")

        approval_result = safe_write_bytes(
            target_root=target_root,
            relative_path=config.approval_path,
            content=render_approval(config=config, approved=False).encode("utf-8"),
            force=args.force,
            timestamp=timestamp,
        )

        line = f"{approval_result.action} {approval_result.path.relative_to(target_root).as_posix()}"
        if approval_result.backup_path is not None:
            line += f" (backup: {approval_result.backup_path.relative_to(target_root).as_posix()})"
        print(line)

        if approval_result.action in {"CREATED", "OVERWRITTEN"}:
            updated_state = {
                "spec": update_state_for_spec_rejected,
                "plan": update_state_for_plan_rejected,
                "diff": update_state_for_diff_rejected,
                "final": update_state_for_final_rejected,
            }[args.gate](state)
            state_result = write_state_payload(
                target_root=target_root,
                state=updated_state,
                force=True,
                timestamp=timestamp,
            )
            state_line = f"{state_result.action} {state_result.path.relative_to(target_root).as_posix()}"
            if state_result.backup_path is not None:
                state_line += f" (backup: {state_result.backup_path.relative_to(target_root).as_posix()})"
            print(state_line)
            if updated_state.get("mode") == "large":
                task_results = [
                    safe_write_bytes(
                        target_root=target_root,
                        relative_path=task_approval_relative_path(updated_state),
                        content=render_decision_approval_json(config=config, approved=False).encode("utf-8"),
                        force=True,
                        timestamp=timestamp,
                    ),
                    safe_write_bytes(
                        target_root=target_root,
                        relative_path=rca_relative_path(updated_state),
                        content=render_rca(state=updated_state, config=config).encode("utf-8"),
                        force=True,
                        timestamp=timestamp,
                    ),
                    safe_write_bytes(
                        target_root=target_root,
                        relative_path=INDEX_PATH,
                        content=render_check_rules_index().encode("utf-8"),
                        force=False,
                        timestamp=timestamp,
                    ),
                    safe_write_bytes(
                        target_root=target_root,
                        relative_path=check_rule_draft_relative_path(updated_state, args.gate),
                        content=render_check_rule_draft(state=updated_state, config=config).encode("utf-8"),
                        force=True,
                        timestamp=timestamp,
                    ),
                ]
                task_supplement = load_active_task_supplement(target_root, updated_state)
                if task_supplement is not None and task_supplement.payload is not None:
                    updated_task = update_task_payload_status(
                        task_supplement.payload,
                        status=task_status_for_decision(gate=args.gate, approved=False),
                    )
                    task_results.append(
                        safe_write_bytes(
                            target_root=target_root,
                            relative_path=active_task_supplement_relative_path(updated_state),
                            content=(json.dumps(updated_task, indent=2, ensure_ascii=True) + "\n").encode("utf-8"),
                            force=True,
                            timestamp=timestamp,
                        )
                    )
                for task_result in task_results:
                    task_line = f"{task_result.action} {task_result.path.relative_to(target_root).as_posix()}"
                    if task_result.backup_path is not None:
                        task_line += f" (backup: {task_result.backup_path.relative_to(target_root).as_posix()})"
                    print(task_line)
        else:
            print("state unchanged; use --force to regenerate approval")

        return 0
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
