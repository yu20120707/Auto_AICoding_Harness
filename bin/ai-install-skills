#!/usr/bin/env python3
from __future__ import annotations

import argparse
from pathlib import Path
import sys


REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from core.skill_install import default_skills_dest, install_all_skills


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Install all Auto_AICoding_Harness skills into the global Codex skills directory.")
    parser.add_argument("--force", action="store_true", help="overwrite existing global skills after backing them up")
    parser.add_argument(
        "--dest",
        type=Path,
        default=default_skills_dest(),
        help="destination skills directory (default: $CODEX_HOME/skills or ~/.codex/skills)",
    )
    return parser.parse_args()


def main() -> int:
    try:
        args = parse_args()
        results = install_all_skills(
            skills_root=REPO_ROOT / "skills",
            dest_root=args.dest.expanduser(),
            force=args.force,
        )

        for result in results:
            line = f"{result.action} {result.name} -> {result.path}"
            if result.backup_path is not None:
                line += f" (backup: {result.backup_path})"
            print(line)

        return 0
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
