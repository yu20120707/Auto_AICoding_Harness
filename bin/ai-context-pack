#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import datetime
from pathlib import Path
import sys


REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from core.context import CONTEXT_PACK_PATH, collect_optional_git_summary, render_context_pack
from core.context_manifest import build_default_context_manifest_entries, context_manifest_relative_path, render_context_manifest
from core.safe_write import safe_write_bytes
from core.state import STATE_RELATIVE_PATH, load_state
from core.task_chain import sync_large_task_chain


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Generate a compact context pack for the current harness state.")
    parser.add_argument("--force", action="store_true", help="overwrite existing context-pack after backing it up")
    return parser.parse_args()


def require_initialized_state(target_root: Path) -> dict:
    state_path = target_root / STATE_RELATIVE_PATH
    if not state_path.exists():
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")
    state = load_state(target_root)
    if state is None:
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")
    return state


def main() -> int:
    try:
        args = parse_args()
        target_root = Path.cwd()
        state = require_initialized_state(target_root)
        git_summary = collect_optional_git_summary(target_root)
        timestamp = datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")

        if state.get("mode") == "large":
            manifest_entries = build_default_context_manifest_entries(target_root, state)
            manifest_result = safe_write_bytes(
                target_root=target_root,
                relative_path=context_manifest_relative_path(state),
                content=render_context_manifest(manifest_entries).encode("utf-8"),
                force=args.force,
                timestamp=timestamp,
            )
            manifest_line = f"{manifest_result.action} {manifest_result.path.relative_to(target_root).as_posix()}"
            if manifest_result.backup_path is not None:
                manifest_line += f" (backup: {manifest_result.backup_path.relative_to(target_root).as_posix()})"
            print(manifest_line)

        result = safe_write_bytes(
            target_root=target_root,
            relative_path=CONTEXT_PACK_PATH,
            content=render_context_pack(target_root, state, git_summary).encode("utf-8"),
            force=args.force,
            timestamp=timestamp,
        )

        line = f"{result.action} {result.path.relative_to(target_root).as_posix()}"
        if result.backup_path is not None:
            line += f" (backup: {result.backup_path.relative_to(target_root).as_posix()})"
        print(line)
        if result.action in {"CREATED", "OVERWRITTEN"}:
            sync_results = sync_large_task_chain(
                target_root=target_root,
                state=state,
                force=args.force,
                timestamp=timestamp,
            )
            for sync_result in sync_results:
                sync_line = f"{sync_result.action} {sync_result.path.relative_to(target_root).as_posix()}"
                if sync_result.backup_path is not None:
                    sync_line += f" (backup: {sync_result.backup_path.relative_to(target_root).as_posix()})"
                print(sync_line)
        return 0
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
