#!/usr/bin/env python3
from __future__ import annotations

import argparse
from datetime import datetime
import json
from pathlib import Path
import sys


REPO_ROOT = Path(__file__).resolve().parents[1]
if str(REPO_ROOT) not in sys.path:
    sys.path.insert(0, str(REPO_ROOT))

from core.review import collect_git_diff_data, ensure_git_repo, render_diff_review
from core.review import build_final_review, build_plan_review, build_spec_review, require_review_input_exists
from core.review_gate import render_task_review, render_waiting_approval_json, task_approval_relative_path, task_review_relative_path, task_status_for_review_gate, update_task_payload_status
from core.safe_write import safe_write_bytes
from core.state import (
    STATE_RELATIVE_PATH,
    load_state,
    update_state_for_diff_review,
    update_state_for_final_review,
    update_state_for_plan_review,
    update_state_for_spec_review,
    write_state_payload,
)
from core.state_machine import assert_review_allowed
from core.task_chain import sync_large_task_chain
from core.task_state import active_task_supplement_relative_path, load_active_task_supplement


REVIEW_PATH = Path(".ai") / "reviews" / "diff-review.md"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Generate review materials for harness-managed changes.")
    parser.add_argument("review_type", choices=["diff", "spec", "plan", "final"])
    parser.add_argument("--force", action="store_true", help="overwrite existing review material after backing it up")
    return parser.parse_args()


def require_initialized_state(target_root: Path) -> dict:
    state_path = target_root / STATE_RELATIVE_PATH
    if not state_path.exists():
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")

    state = load_state(target_root)
    if state is None:
        raise RuntimeError("target repository is not initialized: missing .ai/state.json")

    return state


def main() -> int:
    try:
        args = parse_args()
        target_root = Path.cwd()
        state = require_initialized_state(target_root)
        assert_review_allowed(state, args.review_type)
        timestamp = datetime.now().astimezone().strftime("%Y%m%d-%H%M%S")
        skipped_message = "state unchanged; use --force to regenerate diff review"

        if args.review_type == "diff":
            ensure_git_repo(target_root)
            diff_data = collect_git_diff_data(target_root)
            review_result = safe_write_bytes(
                target_root=target_root,
                relative_path=REVIEW_PATH,
                content=render_diff_review(diff_data).encode("utf-8"),
                force=args.force,
                timestamp=timestamp,
            )
            update_state = update_state_for_diff_review
        else:
            require_review_input_exists(target_root, args.review_type)
            artifact = {
                "spec": build_spec_review,
                "plan": build_plan_review,
                "final": lambda: build_final_review(target_root),
            }[args.review_type]()
            review_result = safe_write_bytes(
                target_root=target_root,
                relative_path=artifact.relative_path,
                content=artifact.content.encode("utf-8"),
                force=args.force,
                timestamp=timestamp,
            )
            skipped_message = artifact.skipped_message
            update_state = {
                "spec": update_state_for_spec_review,
                "plan": update_state_for_plan_review,
                "final": update_state_for_final_review,
            }[args.review_type]

        line = f"{review_result.action} {review_result.path.relative_to(target_root).as_posix()}"
        if review_result.backup_path is not None:
            line += f" (backup: {review_result.backup_path.relative_to(target_root).as_posix()})"
        print(line)

        if review_result.action in {"CREATED", "OVERWRITTEN"}:
            updated_state = update_state(state)
            state_result = write_state_payload(
                target_root=target_root,
                state=updated_state,
                force=True,
                timestamp=timestamp,
            )
            state_line = f"{state_result.action} {state_result.path.relative_to(target_root).as_posix()}"
            if state_result.backup_path is not None:
                state_line += f" (backup: {state_result.backup_path.relative_to(target_root).as_posix()})"
            print(state_line)
            task_supplement = load_active_task_supplement(target_root, updated_state)
            if updated_state.get("mode") == "large" and task_supplement is not None and task_supplement.payload is not None:
                task_review_result = safe_write_bytes(
                    target_root=target_root,
                    relative_path=task_review_relative_path(updated_state),
                    content=render_task_review(
                        review_type=args.review_type,
                        source_path=review_result.path.relative_to(target_root),
                        review_text=review_result.path.read_text(encoding="utf-8"),
                    ).encode("utf-8"),
                    force=True,
                    timestamp=timestamp,
                )
                task_approval_result = safe_write_bytes(
                    target_root=target_root,
                    relative_path=task_approval_relative_path(updated_state),
                    content=render_waiting_approval_json(
                        review_type=args.review_type,
                        review_text=review_result.path.read_text(encoding="utf-8"),
                    ).encode("utf-8"),
                    force=True,
                    timestamp=timestamp,
                )
                updated_task = update_task_payload_status(
                    task_supplement.payload,
                    status=task_status_for_review_gate(args.review_type),
                )
                task_state_result = safe_write_bytes(
                    target_root=target_root,
                    relative_path=active_task_supplement_relative_path(updated_state),
                    content=(json.dumps(updated_task, indent=2, ensure_ascii=True) + "\n").encode("utf-8"),
                    force=True,
                    timestamp=timestamp,
                )
                for task_result in [task_review_result, task_approval_result, task_state_result]:
                    task_line = f"{task_result.action} {task_result.path.relative_to(target_root).as_posix()}"
                    if task_result.backup_path is not None:
                        task_line += f" (backup: {task_result.backup_path.relative_to(target_root).as_posix()})"
                    print(task_line)
            sync_results = sync_large_task_chain(
                target_root=target_root,
                state=updated_state,
                force=args.force,
                timestamp=timestamp,
            )
            for sync_result in sync_results:
                sync_line = f"{sync_result.action} {sync_result.path.relative_to(target_root).as_posix()}"
                if sync_result.backup_path is not None:
                    sync_line += f" (backup: {sync_result.backup_path.relative_to(target_root).as_posix()})"
                print(sync_line)
        else:
            print(skipped_message)

        return 0
    except Exception as exc:
        print(f"error: {exc}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
