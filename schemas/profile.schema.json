{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Auto_AICoding_Harness Profile",
  "type": "object",
  "required": [
    "name",
    "display_name",
    "version",
    "languages",
    "domains",
    "risk_triggers",
    "verification"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "domains": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "risk_triggers": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "verification": {
      "type": "object",
      "required": ["build", "test", "sanitizer", "benchmark"],
      "properties": {
        "build": {
          "type": "string",
          "minLength": 1
        },
        "test": {
          "type": "string",
          "minLength": 1
        },
        "sanitizer": {
          "type": "string",
          "minLength": 1
        },
        "benchmark": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
